# =============================================
# monetary-policy-var — .gitignore
# =============================================

# --- Environment & Secrets ---
.env
.env.local
*.key
venv/
.venv/
env/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
*.ipynb_checkpoints

# --- Data (raw files can be large; keep processed if small) ---
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json
# Uncomment below if processed data is also large:
# data/processed/*.csv

# --- Outputs (regenerated by notebooks) ---
outputs/figures/*.png
outputs/figures/*.pdf
outputs/tables/*.tex
outputs/tables/*.csv

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- Logs ---
*.log
logs/
